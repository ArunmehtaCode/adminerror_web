{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/admin/$1"
    },
    {
      "src": "/api/(.*)",
      "status": 404,
      "statusText": "API Not Available in Frontend-Only Deployment"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
